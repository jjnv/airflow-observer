# Copy this file to .env and replace every value marked "replace-".

DEMO_MODE=false

# Postgres used by Airflow Observer.
POSTGRES_USER=observer
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
POSTGRES_DB=observer
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://observer:replace-with-a-strong-postgres-password@postgres:5432/observer

# Backend.
DEFAULT_WORKSPACE_ID=replace-with-your-workspace-id
DEFAULT_API_KEY=replace-with-a-random-observer-api-key
CORS_ORIGINS=http://localhost:3000
BACKEND_PORT=8000
SLACK_WEBHOOK_URL=

# Frontend.
FRONTEND_PORT=3000
OBSERVER_API_URL_INTERNAL=http://backend:8000

# Agent connection to your Airflow instance.
AIRFLOW_URL=https://airflow.example.com
AIRFLOW_USERNAME=replace-with-airflow-username
AIRFLOW_PASSWORD=replace-with-airflow-password
AIRFLOW_TOKEN=
OBSERVER_API_KEY=replace-with-the-same-random-observer-api-key
WORKSPACE_ID=replace-with-your-workspace-id
AIRFLOW_INSTANCE_UID=replace-with-a-stable-airflow-instance-id
AIRFLOW_INSTANCE_NAME=replace-with-a-readable-airflow-name
AGENT_VERSION=0.1.0
POLL_INTERVAL_SECONDS=60
DAG_FILTER_REGEX=.*
DAG_LIMIT=100
RUN_LIMIT=10
